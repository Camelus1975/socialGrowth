# ==============================================
# App Founder Growth Suite - Environment Variables
# ==============================================

# Supabase Connection (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Encryption (REQUIRED)
ENCRYPTION_SECRET=generate_a_strong_random_secret_here
ENCRYPTION_SALT=generate_a_strong_random_salt_here

# Server Settings
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://your-production-domain.up.railway.app

# Redis Connection (Required for background workers)
REDIS_URL=rediss://default:your_redis_password@your-redis-host:6379

# OpenAI (Required for AI features)
OPENAI_API_KEY=sk-your-openai-key

# Replicate (Required for FLUX image generation)
REPLICATE_API_TOKEN=r8_your_replicate_token

# Meta / Facebook / Instagram OAuth
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_REDIRECT_URI=https://your-production-domain.up.railway.app/api/auth/meta/callback
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_system_user_token
